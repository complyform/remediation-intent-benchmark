    given-names: "Anas"
    orcid: "https://orcid.org/0009-0004-4176-1516"
    affiliation: "ComplyForm LLC"
keywords:
  - compliance automation
  - infrastructure as code
  - remediation verification
  - control intent
  - cloud security
  - benchmark
license: Apache-2.0
